// Education Center ERP — Prisma schema
// Canonical provider is PostgreSQL (production). For zero-setup local dev on
// SQLite, run `npm run db:use-sqlite` (and switch back with `db:use-postgres`
// before committing — the swap script only edits the provider line below).
// The schema is intentionally portable: enum-like values are stored as strings
// (see lib/enums.ts) and JSON is stored as text, so no model changes are needed
// when switching providers.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Application users with a role. A user may be linked to a Teacher or Guardian
/// record to power the teacher/parent portals.
model User {
  id           String   @id @default(cuid())
  name         String
  /// Latin-script name, shown when the interface is in English. Optional: the
  /// centre's records are Arabic-first, so this fills in over time and every
  /// display falls back to `name` while it is empty.
  nameEn       String?
  email        String   @unique
  passwordHash String
  role         String   @default("RECEPTIONIST") // ADMIN | ACCOUNTANT | RECEPTIONIST | TEACHER | PARENT
  /// All roles this user may act as (JSON array of role identifiers — built-in
  /// enum values or CustomRole.key). Null/empty means just `role`. The active
  /// role lives in the session, not here, so switching never rewrites the row.
  roleKeys     String?
  locale       String   @default("ar") // ar | en
  active       Boolean  @default(true)

  teacherId  String?  @unique
  teacher    Teacher? @relation(fields: [teacherId], references: [id])
  guardianId String?  @unique
  guardian   Guardian? @relation(fields: [guardianId], references: [id])
  employeeId String?  @unique
  employee   Employee? @relation(fields: [employeeId], references: [id])

  auditLogs AuditLog[]
  leads     Lead[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Teacher {
  id            String   @id @default(cuid())
  name          String
  /// Latin-script name, shown when the interface is in English. Optional: the
  /// centre's records are Arabic-first, so this fills in over time and every
  /// display falls back to `name` while it is empty.
  nameEn        String?
  phone         String?
  commissionPct Decimal  @default(0) // percentage, e.g. 50 = 50%
  active        Boolean  @default(true)
  notes         String?

  /// Fixed monthly salary paid on top of commission, and any standing deduction.
  fixedSalary     Decimal @default(0)
  fixedDeductions Decimal @default(0)
  /// SESSION | MONTH | TERM — how often a payout is cut. Null falls back to the
  /// centre default setting.
  paymentMode     String?
  /// SALARY | COMMISSION | BOTH — what the teacher is actually owed. Distinct
  /// from paymentMode, which is only about the period. Null inherits the
  /// centre default so changing that setting moves everyone who never opted out.
  earningsMode    String?

  /// Where the teacher is collected from / dropped home by the transport
  /// module. Optional: only teachers who actually get a lift need it.
  address       String?
  homeLat       Float?
  homeLng       Float?

  user         User?
  sessions     Session[]
  payments     Payment[]      // payments allocated to this teacher
  payouts      TeacherPayout[]
  availability TeacherAvailability[]
  templates    PlannerTemplate[]
  students     StudentTeacher[]
  subjects     TeacherSubject[]
  employee     Employee?
  tripStops    TripStop[]
  groups       StudentGroup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Guardian {
  id       String    @id @default(cuid())
  name     String
  /// Latin-script name, shown when the interface is in English. Optional: the
  /// centre's records are Arabic-first, so this fills in over time and every
  /// display falls back to `name` while it is empty.
  nameEn   String?
  phone    String?
  email    String?
  notes    String?
  user     User?
  students Student[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GradeLevel {
  id        String  @id @default(cuid())
  code      String  @unique // ب م | ب | ع | ث | جامعة
  nameAr    String
  nameEn    String
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  priceRules PriceRule[]
  sessions   Session[]
  students   Student[]
  leads      Lead[]
  groups     StudentGroup[]
}

/// Price-per-hour matrix: (grade level x location), versioned by effectiveFrom.
model PriceRule {
  id            String     @id @default(cuid())
  gradeLevelId  String
  gradeLevel    GradeLevel @relation(fields: [gradeLevelId], references: [id])
  location      String     // CENTER | HOME
  pricePerHour  Decimal
  effectiveFrom DateTime   @default(now())
  active        Boolean    @default(true)

  createdAt DateTime @default(now())

  @@unique([gradeLevelId, location, effectiveFrom])
  @@index([gradeLevelId, location])
}

model Student {
  id           String      @id @default(cuid())
  name         String
  /// Latin-script name, shown when the interface is in English. Optional: the
  /// centre's records are Arabic-first, so this fills in over time and every
  /// display falls back to `name` while it is empty.
  nameEn       String?
  phone        String?
  gradeLevelId String?
  gradeLevel   GradeLevel? @relation(fields: [gradeLevelId], references: [id])
  guardianId   String?
  guardian     Guardian?   @relation(fields: [guardianId], references: [id])
  active       Boolean     @default(true)
  notes        String?

  // Home-session check-in support: saved home location (geofence anchor) and a
  // short PIN the student/guardian confirms at check-in.
  address    String?
  homeLat    Float?
  homeLng    Float?
  checkinPin String?
  /// Stable random token behind the student's printable QR card.
  /// Deliberately not the row id: a card can be reissued by rotating this
  /// without touching history, and a lost card never exposes an internal id.
  qrToken    String? @unique
  /// Short code the centre uses to identify the home location (zone/street/
  /// building, a compound name, whatever they already write on the paper
  /// sheet). Shown on planner cards for HOME sessions so the teacher knows
  /// where they are going at a glance.
  homeCode   String?
  /// Where this student usually studies (CENTER | HOME). New sessions default
  /// their location — and therefore their price — from this; each session can
  /// still override it.
  studyLocation String @default("CENTER")
  /// Opt-in to the transport module. Explicit rather than inferred from having
  /// coordinates: most families drive their own child, and generating a car for
  /// every student with a saved home pin would flood the planner.
  needsTransport Boolean @default(false)
  /// School year 1-12, distinct from gradeLevel (the pricing band). Lets the
  /// office group students by their actual class — five grade-10 students
  /// together — which the broad band (Secondary) cannot express.
  gradeYear Int?

  sessions  Session[]
  payments  Payment[]
  packages  Package[]
  templates PlannerTemplate[]
  leads     Lead[]
  teachers     StudentTeacher[]
  cheques      Cheque[]
  tripStops    TripStop[]
  groupMembers GroupMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

/// A teacher's recurring weekly working window. Several rows per weekday are
/// allowed (e.g. a morning block and an evening block). Times are minutes from
/// midnight in the same wall-clock convention as `Session.date`.
///
/// A teacher with no rows at all is treated as "always available" — the
/// availability warning is opt-in per teacher, not a centre-wide gate.
model TeacherAvailability {
  id        String  @id @default(cuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  /// 0 = Sunday … 6 = Saturday (matches JS `Date.getUTCDay`).
  weekday   Int
  startMin  Int
  endMin    Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId, weekday])
}

/// A recurring weekly planner entry. "Generate day from template" turns every
/// row matching the day's weekday into a DRAFT session, so a normal week can be
/// laid out in one click and then adjusted.
model PlannerTemplate {
  id        String  @id @default(cuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  /// 0 = Sunday … 6 = Saturday (matches JS `Date.getUTCDay`).
  weekday   Int
  startMin  Int
  hours     Decimal
  location  String // CENTER | HOME
  active    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId, weekday])
  @@index([weekday])
}

/// A single tutoring session (حصة). Price is resolved from the PriceRule matrix
/// at creation time and snapshotted onto the row.
model Session {
  id           String     @id @default(cuid())
  date         DateTime
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id])
  /// Nullable so a walk-in can be recorded before anyone knows who
  /// taught it — no payroll moves until a teacher is assigned.
  teacherId    String?
  teacher      Teacher?   @relation(fields: [teacherId], references: [id])
  /// The saved group ("course") this booking came from, when it was made
  /// through group booking with a loaded group. Powers the group 360 view.
  groupId      String?
  group        StudentGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  gradeLevelId String
  gradeLevel   GradeLevel @relation(fields: [gradeLevelId], references: [id])
  /// Optional at booking. When set, shown on the booking card. A session's
  /// subject is independent of the teacher's subject list — a cover lesson can
  /// be any subject — so this is not constrained to the teacher's subjects.
  subjectId    String?
  subject      Subject?   @relation(fields: [subjectId], references: [id])
  location     String     // CENTER | HOME
  hours        Decimal
  pricePerHour Decimal
  total        Decimal
  paymentStatus String    @default("UNPAID") // PAID | PARTIAL | UNPAID
  packageId    String?
  package      Package?   @relation(fields: [packageId], references: [id])
  notes        String?
  branchId     String?    // future multi-branch seam

  // Scheduling & attendance. `date` holds the start datetime; `hours` is the
  // planned duration. Attendance drives status: a completed session is billable.
  status           String    @default("SCHEDULED") // SCHEDULED | CHECKED_IN | COMPLETED | NO_SHOW | CANCELLED
  studentCheckInAt DateTime?
  studentCheckOutAt DateTime?
  teacherCheckInAt DateTime?
  checkInMethod    String?   // KIOSK | GPS | QR | MANUAL
  checkInLat       Float?
  checkInLng       Float?
  actualHours      Decimal?  // measured from check-in → check-out

  /// Trial lesson: booked at zero price as a DRAFT so it shows on the calendar
  /// and planner without ever touching the ledger.
  isTrial     Boolean @default(false)
  leadId      String?
  lead        Lead?   @relation(fields: [leadId], references: [id])

  allocations PaymentAllocation[]
  tripStops   TripStop[]
  /// True once this session's hours have been deducted from its package, so
  /// confirm/undo cycles can never double-count.
  packageApplied Boolean @default(false)
  /// Completed by the nightly sweep rather than by a person. Auto-completing
  /// makes a session billable without anyone confirming the lesson happened,
  /// so it is flagged for the review list rather than done silently.
  autoCompleted  Boolean @default(false)
  /// Recorded without a teacher (walk-in). Surfaces in the check-in
  /// review list until an admin allocates one.
  needsTeacher   Boolean @default(false)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([studentId])
  @@index([teacherId])
  @@index([status])
  @@index([groupId])
}

/// Prepaid bundle of hours (باقة). Sessions decrement hoursUsed.
model Package {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id])
  totalHours  Decimal
  hoursUsed   Decimal   @default(0)
  price       Decimal
  purchasedAt DateTime  @default(now())
  expiresAt   DateTime?
  status      String    @default("ACTIVE") // ACTIVE | COMPLETED | EXPIRED
  notes       String?

  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// A collected payment / receipt (الدخل المحصل). Optionally allocated to a teacher.
model Payment {
  id        String   @id @default(cuid())
  date      DateTime
  receiptNo String   @unique
  studentId String?
  student   Student? @relation(fields: [studentId], references: [id])
  amount    Decimal
  method    String   @default("CASH") // CASH | POS | QPAY | TRANSFER
  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id])
  packageId String?
  notes     String?
  branchId  String?

  allocations PaymentAllocation[]
  cheque      Cheque?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([studentId])
}

/// Links part of a payment to a specific session, driving that session's
/// paymentStatus (PAID / PARTIAL). Payments may stay unallocated (legacy rows).
model PaymentAllocation {
  id        String  @id @default(cuid())
  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  amount    Decimal

  createdAt DateTime @default(now())

  @@unique([paymentId, sessionId])
  @@index([sessionId])
}

/// A subject a lesson can be about (رياضيات، فيزياء، …). A reference table like
/// grade levels and expense categories: managed in Settings, shown in the
/// booking form, and surfaced on the booking card when chosen.
model Subject {
  id        String  @id @default(cuid())
  nameAr    String
  nameEn    String
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  teachers TeacherSubject[]
  sessions Session[]
  groups   StudentGroup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

/// Which subjects a teacher teaches. A teacher may teach one or many; a subject
/// may be taught by many teachers. Explicit join, matching StudentTeacher.
model TeacherSubject {
  id        String  @id @default(cuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([teacherId, subjectId])
  @@index([subjectId])
}

model ExpenseCategory {
  id        String    @id @default(cuid())
  nameAr    String
  nameEn    String
  sortOrder Int       @default(0)
  active    Boolean   @default(true)
  expenses  Expense[]
  /// Expense account this category posts to when the accounting module is on.
  /// Null falls back to 5900 (miscellaneous) — mapping is a column, not a
  /// table: one account per category is all a small centre needs.
  accountId String?
  account   Account?  @relation(fields: [accountId], references: [id])
}

model Expense {
  id          String          @id @default(cuid())
  date        DateTime
  receiptNo   String?
  description String
  categoryId  String
  category    ExpenseCategory @relation(fields: [categoryId], references: [id])
  amount      Decimal
  paidTo      String?
  branchId    String?
  /// DRAFT | APPROVED | POSTED (lib/enums.ts). Existing rows are real paid
  /// expenses, so the default is APPROVED. With accounting on, new expenses
  /// start DRAFT and the approve action posts them to the journal (POSTED).
  status      String          @default("APPROVED")
  /// Optional vendor link; `paidTo` free text stays as the fallback.
  supplierId  String?
  supplier    Supplier?       @relation(fields: [supplierId], references: [id])
  cheque      Cheque?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([categoryId])
  fuelLog        FuelLog?
  maintenanceLog MaintenanceLog?
}

/// Vendor register: who the centre buys from and pays. Linked from expenses
/// (and outgoing cheques in the cheque module).
model Supplier {
  id      String  @id @default(cuid())
  name    String
  nameEn  String?
  phone   String?
  email   String?
  taxNo   String?
  address String?
  notes   String?
  active  Boolean @default(true)

  expenses Expense[]
  cheques  Cheque[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  fuelLogs        FuelLog[]
  maintenanceLogs MaintenanceLog[]
}

/// A teacher payroll run for a period.
model TeacherPayout {
  id              String   @id @default(cuid())
  /// Nullable since HR phase 4: a receptionist's payslip has no teacher. Every
  /// pre-HR row still has it set. A hand-applied CHECK ("payslip_has_subject")
  /// guarantees at least one of teacherId/employeeId is present — Prisma
  /// cannot manage CHECK constraints, so do not expect it in a migrate diff.
  teacherId       String?
  teacher         Teacher? @relation(fields: [teacherId], references: [id])
  periodStart     DateTime
  periodEnd       DateTime
  /// Commission actually due — commissionPct applied to income collected.
  grossCommission Decimal
  /// Commission the sessions would earn once fully collected (for comparison).
  expectedCommission Decimal @default(0)
  fixedSalary     Decimal  @default(0)
  deductions      Decimal  @default(0)
  advances        Decimal  @default(0)
  netPaid         Decimal
  status          String   @default("DRAFT") // DRAFT | PAID
  notes           String?
  /// Mode this payout was generated under (SESSION | MONTH | TERM), snapshotted
  /// so a later change to the teacher's setting can't rewrite payslip history.
  payMode         String?
  /// Earnings mode in force when this payout was cut (SALARY | COMMISSION |
  /// BOTH), snapshotted for the same reason: a payslip must keep explaining the
  /// figures it was printed with.
  earnMode        String?
  /// Term this payout covers, when generated in TERM mode.
  termId          String?
  term            Term?    @relation(fields: [termId], references: [id])

  /// --- HR module (additive; null on every pre-HR row) ---
  /// The employee this payslip pays. A teacher-who-is-an-employee carries BOTH
  /// teacherId and employeeId on one row — one payslip, not two to reconcile.
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])
  /// The batch this payslip was cut in. Null = ad-hoc single payout.
  runId String?
  run   PayrollRun? @relation(fields: [runId], references: [id])
  /// WPS/gratuity split of fixedSalary. fixedSalary is kept written as their
  /// sum so every reader that predates the HR module stays correct unchanged.
  basicSalary Decimal @default(0)
  allowances  Decimal @default(0)
  /// WPS "Extra hours" / "Extra income" columns.
  overtime    Decimal @default(0)
  extraIncome Decimal @default(0)
  /// WPS "Number of Working days". Null on pre-HR rows; the SIF generator
  /// refuses to emit a record without it rather than guessing 30.
  workingDays     Int?
  unpaidLeaveDays Decimal @default(0)
  /// CASH | BANK | CHEQUE — surfaces as the WPS Payment Type.
  paymentMethod String?
  paidAt        DateTime?
  cheque        Cheque?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId])
  @@index([employeeId])
  @@index([runId])
  /// One payslip per employee per run — a double-clicked bulk generate must not
  /// become a double payment. NULLs are distinct in Postgres, so legacy rows
  /// (employeeId null) are unaffected — the property StudentTeacher relies on.
  @@unique([employeeId, runId])
}

/// Immutable audit trail for financial records. before/after stored as JSON text.
model AuditLog {
  id       String  @id @default(cuid())
  userId   String?
  user     User?   @relation(fields: [userId], references: [id])
  entity   String
  entityId String
  action   String // CREATE | UPDATE | DELETE
  before   String?
  after    String?

  createdAt DateTime @default(now())

  @@index([entity, entityId])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

/// Login attempts (success and failure) for rate limiting and security audit.
model LoginAttempt {
  id      String   @id @default(cuid())
  email   String
  ip      String?
  success Boolean  @default(false)
  at      DateTime @default(now())

  @@index([email, at])
}

/// An academic term. Drives calendar context and term-based teacher payouts.
model Term {
  id        String   @id @default(cuid())
  nameAr    String
  nameEn    String
  startDate DateTime
  endDate   DateTime
  active    Boolean  @default(true)

  payouts TeacherPayout[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate])
}

/// A configured third-party integration (messaging, etc.). Credentials are stored
/// here rather than in code/env so the repo stays secret-free and non-technical
/// admins can manage them from Settings → Integrations.
model Integration {
  id       String  @id @default(cuid())
  provider String  @unique // EASYAICONNECT | ... (see lib/integrations/registry.ts)
  enabled  Boolean @default(false)

  baseUrl String?
  apiKey  String?
  /// Provider-specific extras as JSON text (endpoint paths, sender id, …).
  config  String?
  /// JSON array of enabled event keys, e.g. ["SESSION_BOOKED","PAYMENT_RECEIVED"].
  events  String?
  /// JSON array of audiences to notify: ["TEACHER","PARENT","STUDENT"].
  audiences String?

  lastTestAt  DateTime?
  lastTestOk  Boolean?
  lastTestMsg String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Delivery record for every outbound notification attempt.
model NotificationLog {
  id        String  @id @default(cuid())
  provider  String
  event     String
  audience  String // TEACHER | PARENT | STUDENT
  recipient String // phone number or provider contact id
  status    String // SENT | FAILED | SKIPPED
  message   String?
  error     String?
  entityType String?
  entityId   String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([event])
}

/// A prospective student before they enrol. Converting a lead creates the real
/// Student (and Guardian) records and links any trial sessions already booked.
model Lead {
  id        String  @id @default(cuid())
  name      String
  /// Latin-script name, shown when the interface is in English. Optional: the
  /// centre's records are Arabic-first, so this fills in over time and every
  /// display falls back to `name` while it is empty.
  nameEn    String?
  phone     String?
  email     String?
  /// Where they came from — walk-in, referral, Instagram, etc. Free text so the
  /// centre can track whatever channels they actually use.
  source    String?
  /// NEW | CONTACTED | TRIAL | ENROLLED | LOST
  status    String  @default("NEW")
  notes     String?
  /// Grade level they are asking about, when known.
  gradeLevelId String?
  gradeLevel   GradeLevel? @relation(fields: [gradeLevelId], references: [id])
  followUpAt   DateTime?
  assignedToUserId String?
  assignedTo       User?  @relation(fields: [assignedToUserId], references: [id])
  /// Set once converted, so the lead keeps a trail to the enrolled student.
  studentId String?
  student   Student? @relation(fields: [studentId], references: [id])

  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([followUpAt])
}

/// Which teachers a student normally works with.
///
/// Lets the booking dialogs offer the two or three relevant teachers instead of
/// the whole roster. Scoped per academic year so last year's pairings don't
/// clutter this year's lists.
model StudentTeacher {
  id        String  @id @default(cuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  /// Null until the centre sets up academic years, so assignments work before
  /// then and simply become year-scoped once a year exists.
  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // Postgres treats NULLs as distinct, so this can't enforce uniqueness while
  // the year is null. Saving replaces the whole set instead, which makes
  // duplicates impossible regardless.
  @@unique([studentId, teacherId, academicYearId])
  @@index([studentId])
  @@index([teacherId])
  @@index([academicYearId])
}

/// A school year. Archiving one freezes its money and attendance records.
///
/// Membership is decided by date range rather than a foreign key on every
/// table: adding `academicYearId` to sessions, payments, payouts and expenses
/// would mean backfilling four large tables and keeping the column in step on
/// every write, for information the record's own date already carries.
model AcademicYear {
  id        String   @id @default(cuid())
  nameAr    String
  nameEn    String
  startDate DateTime
  endDate   DateTime
  /// Archived years reject new/edited/deleted sessions, payments, payouts and
  /// expenses. Student, teacher and guardian records stay editable so a
  /// misspelled name can still be fixed, and reports keep reading normally.
  archived  Boolean  @default(false)
  /// The year new work defaults into. Exactly one should be current.
  isCurrent Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments StudentTeacher[]

  @@index([archived])
  @@index([startDate, endDate])
}

/// ------------------------------------------------------------------- HR ----

/// Every person on the establishment: teachers, reception, admin, drivers.
/// Separate from Teacher (an academic/commission entity) and from User (a
/// login), because Qatar's WPS legally requires every employee listed
/// regardless of whether they teach or can log in.
///
/// Identity fields are optional throughout: a record must be creatable on the
/// hire date, before a QID is issued. The WPS export validates presence at
/// export time, so HR is never blocked from recording a new hire.
model Employee {
  id         String  @id @default(cuid())
  /// The centre's own staff number, printed on payslips.
  employeeNo String? @unique
  name       String
  nameEn     String?
  phone      String?
  email      String?
  /// Where a driver's shift starts and ends. Deliberately separate from
  /// Teacher's copy: for a teacher-who-drives they answer different questions
  /// (where to collect the teacher vs where the driver begins the day).
  address    String?
  homeLat    Float?
  homeLng    Float?

  qid         String?   @unique
  visaId      String?
  passportNo  String?
  nationality String?
  dob         DateTime?

  hireDate DateTime?
  /// Last working day. Set at final settlement; also stops leave accrual.
  endDate      DateTime?
  jobTitle     String?
  department   String? // TEACHING | RECEPTION | ADMIN | TRANSPORT | OTHER
  contractType String? // UNLIMITED | LIMITED — the expiry lives on a CONTRACT document
  status       String  @default("ACTIVE") // ACTIVE | ON_LEAVE | TERMINATED

  iban     String?
  bankName String?
  /// The bank's official WPS short code (Appendix B). Deliberately separate
  /// from bankName: the SIF is parsed by the bank, and free text there gets
  /// the whole file rejected.
  bankShortName   String?
  salaryFrequency String  @default("M") // WPS: M monthly | B bi-weekly

  /// Gratuity under Art. 54 is 21 days of BASIC only, so the basic/allowances
  /// split is structural, not cosmetic.
  basicSalary Decimal @default(0)
  allowances  Decimal @default(0)

  /// Set when this employee is also a teacher. Once set, basicSalary +
  /// allowances replace Teacher.fixedSalary as the salary source (see
  /// lib/salary-source.ts) so the two can never both be paid.
  teacherId String?  @unique
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  notes String?

  user             User?
  documents        EmployeeDocument[]
  leave            LeaveRequest[]
  leaveAdjustments LeaveAdjustment[]
  payslips         TeacherPayout[]
  settlements      EndOfService[]
  /// Set only while this employee drives (transport module).
  driver Driver?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([name])
}

/// Every expiring document. Deliberately the ONLY place an expiry date lives —
/// QID, visa and contract expiry are NOT also columns on Employee: one date per
/// fact means one alerting query and no "which of the two is right" bug the
/// first time someone renews in the wrong screen. A renewal is a new row, so
/// history survives; alerts read the latest row per type.
model EmployeeDocument {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type       String // QID | VISA | PASSPORT | CONTRACT | HEALTH_CARD | LICENCE | OTHER
  number     String?
  issuedOn   DateTime?
  expiresOn  DateTime?
  /// Path to the scan on disk — never a DB blob, which would put passport
  /// scans into every nightly pg_dump.
  fileUrl String?
  notes   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([expiresOn])
}

model LeaveType {
  id     String  @id @default(cuid())
  code   String  @unique // ANNUAL | SICK | UNPAID | MATERNITY | HAJJ | OTHER
  nameAr String
  nameEn String
  paid   Boolean @default(true)
  /// Whether days under this type still count as service for gratuity. False
  /// for UNPAID — the case that can drop someone below the one-year cliff.
  countsAsService Boolean  @default(true)
  annualCapDays   Decimal?
  active          Boolean  @default(true)
}

model LeaveRequest {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  /// Snapshot of LeaveType.code, matching how payMode/earnMode are snapshotted:
  /// renaming or retiring a type must not rewrite an approved request.
  typeCode  String
  startDate DateTime
  endDate   DateTime
  /// Computed and frozen at submission — a policy change cannot silently alter
  /// what an approved request said.
  days   Decimal
  status String  @default("PENDING") // PENDING | APPROVED | REJECTED | CANCELLED
  reason String?

  decidedByUserId String?
  decidedAt       DateTime?
  decisionNote    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId, startDate])
  @@index([status])
}

/// Opening balances, carry-forward and manual corrections. Without this the
/// module is unusable on day one: staff have already taken leave this year
/// that the system has never seen.
model LeaveAdjustment {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  typeCode   String
  /// Positive credits days, negative debits them.
  days            Decimal
  effectiveOn     DateTime
  reason          String
  createdByUserId String?
  createdAt       DateTime @default(now())

  @@index([employeeId, typeCode])
}

/// One batch of payslips: selecting many employees and generating in one
/// action produces one run and N TeacherPayout rows.
model PayrollRun {
  id String @id @default(cuid())
  /// The YYYY-MM this run pays — WPS carries Salary Year+Month in its header.
  month       String
  periodStart DateTime
  periodEnd   DateTime
  status      String @default("DRAFT") // DRAFT | APPROVED | PAID
  /// Default for the run; per-payslip paymentMethod may override.
  paymentMethod   String?
  paidAt          DateTime?
  notes           String?
  createdByUserId String?

  items   TeacherPayout[]
  exports WpsExport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Not unique on month: off-cycle and corrective runs are real; the create
  /// action warns instead.
  @@index([month])
}

/// Proof of what was filed with the bank. The bytes are not stored — the
/// generator is deterministic, so the file is reproducible from the run.
model WpsExport {
  id    String     @id @default(cuid())
  runId String
  run   PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  /// The payer bank the file was named for (Appendix B short code).
  bankCode        String
  sifVersion      String
  fileName        String
  recordCount     Int
  totalAmount     Decimal
  /// sha256 of the emitted bytes.
  checksum        String?
  createdByUserId String?
  createdAt       DateTime @default(now())

  @@index([runId])
}

/// Final end-of-service settlement. Live gratuity accrual is deliberately NOT
/// stored — it is a pure function of hire date, basic salary, unpaid leave and
/// today. Only the settlement actually paid is a fact worth keeping, and every
/// input is snapshotted so a later salary correction cannot rewrite it.
model EndOfService {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  lastWorkingDay      DateTime
  serviceDays         Int
  serviceYears        Decimal
  basicSalaryAtEnd    Decimal
  unpaidLeaveDays     Decimal @default(0)
  gratuityDaysPerYear Decimal
  gratuityDays        Decimal
  gratuityAmount      Decimal
  unusedLeaveDays     Decimal @default(0)
  unusedLeaveAmount   Decimal @default(0)
  otherDues           Decimal @default(0)
  deductions          Decimal @default(0)
  /// May be negative: a settlement where deductions exceed dues is a real
  /// debt, unlike a payslip net which is floored at zero.
  netSettlement Decimal
  status        String  @default("DRAFT") // DRAFT | PAID
  /// The payslip it was disbursed on, when paid through payroll.
  payslipId String? @unique
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
}

/// --- Accounting (optional module, Setting key `accountingEnabled`) ---

/// Chart of accounts. Codes follow the conventional 4-digit blocks
/// (1000s assets … 5000s expenses). `system` accounts are seeded by
/// `ensureChartOfAccounts` and posting rules depend on their codes, so the
/// delete action refuses them (deactivate instead).
model Account {
  id       String    @id @default(cuid())
  code     String    @unique
  nameAr   String
  nameEn   String
  type     String    // ASSET | LIABILITY | EQUITY | INCOME | EXPENSE (lib/enums.ts)
  parentId String?
  parent   Account?  @relation("AccountTree", fields: [parentId], references: [id])
  children Account[] @relation("AccountTree")
  system   Boolean   @default(false)
  active   Boolean   @default(true)
  notes    String?

  lines             JournalLine[]
  expenseCategories ExpenseCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

/// One double-entry journal entry (header). Lines must balance —
/// sum(debit) = sum(credit) — enforced in the actions, never trusted from a
/// form. `[sourceType, sourceId]` is the idempotency backbone for
/// auto-posting: MANUAL entries carry a null sourceId (NULLs are distinct, so
/// the unique never blocks them).
model JournalEntry {
  id         String  @id @default(cuid())
  date       DateTime
  memo       String
  /// PAYMENT | EXPENSE | PAYROLL | CHEQUE | MANUAL (lib/enums.ts)
  sourceType String  @default("MANUAL")
  /// PAYMENT/EXPENSE → row id; PAYROLL → payout id; CHEQUE → `${id}:${status}`.
  sourceId   String?

  lines       JournalLine[]
  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sourceType, sourceId])
  @@index([date])
}

/// One leg of a journal entry: debit XOR credit > 0 (app-enforced).
model JournalLine {
  id      String       @id @default(cuid())
  entryId String
  entry   JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  accountId String
  account   Account @relation(fields: [accountId], references: [id])

  debit  Decimal @default(0)
  credit Decimal @default(0)
  memo   String?

  @@index([accountId])
  @@index([entryId])
}

/// A physical cheque book: bank, serial range, and the next unused leaf.
/// Outgoing cheques consume `nextNo` inside the issuing transaction.
model ChequeBook {
  id        String  @id @default(cuid())
  bankName  String
  accountNo String?
  startNo   Int
  endNo     Int
  nextNo    Int
  active    Boolean @default(true)
  notes     String?

  cheques Cheque[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// One cheque, incoming (from a student/guardian) or outgoing (to a supplier
/// or payslip). Lifecycle statuses in lib/enums.ts CHEQUE_STATUSES; every
/// transition appends a ChequeEvent and may post ledger hops per the centre's
/// `chequePolicy` setting.
model Cheque {
  id         String  @id @default(cuid())
  direction  String  // INCOMING | OUTGOING
  status     String  @default("DRAFT")
  chequeNo   String
  amount     Decimal @default(0)
  /// Incoming: the drawer's bank/name. Outgoing: the printed payee.
  bankName   String?
  drawerName String?
  payeeName  String?

  bookId     String?
  book       ChequeBook? @relation(fields: [bookId], references: [id])
  supplierId String?
  supplier   Supplier?   @relation(fields: [supplierId], references: [id])
  studentId  String?
  student    Student?    @relation(fields: [studentId], references: [id])
  /// The money document this cheque settles — at most one each way.
  paymentId  String? @unique
  payment    Payment? @relation(fields: [paymentId], references: [id])
  expenseId  String? @unique
  expense    Expense? @relation(fields: [expenseId], references: [id])
  payoutId   String? @unique
  payout     TeacherPayout? @relation(fields: [payoutId], references: [id])

  issueDate     DateTime?
  dueDate       DateTime?
  receivedDate  DateTime?
  depositDate   DateTime?
  clearanceDate DateTime?
  bounceDate    DateTime?
  bounceReason  String?
  bounceFee     Decimal @default(0)

  /// Replacement chain: a bounced cheque points at the cheque replacing it.
  replacedById String? @unique
  replacedBy   Cheque? @relation("ChequeReplacement", fields: [replacedById], references: [id])
  replaces     Cheque? @relation("ChequeReplacement")

  notes       String?
  createdById String?
  events      ChequeEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bookId, chequeNo])
  @@index([status, dueDate])
  @@index([direction])
}

/// Append-only status history for a cheque.
model ChequeEvent {
  id         String  @id @default(cuid())
  chequeId   String
  cheque     Cheque  @relation(fields: [chequeId], references: [id], onDelete: Cascade)
  fromStatus String?
  toStatus   String
  note       String?
  byUserId   String?
  at         DateTime @default(now())

  @@index([chequeId, at])
}

/* --------------------------- Transport: the fleet -------------------------- */

/// A vehicle the centre can dispatch. Kept deliberately thin: everything that
/// expires lives in VehicleDocument, and everything that costs money arrives in
/// Z5 (fuel/maintenance), so this row rarely changes once created.
model Vehicle {
  id    String @id @default(cuid())
  /// Registration plate — the number staff actually say out loud, so it is the
  /// natural key and must be unique.
  plate String @unique
  make  String?
  model String?
  year  Int?
  /// Passenger seats excluding the driver — the capacity the allocator honours.
  capacity   Int     @default(4)
  odometerKm Int     @default(0)
  active     Boolean @default(true)
  notes      String?

  documents VehicleDocument[]
  /// Drivers whose default vehicle this is (back-relation, not ownership).
  drivers Driver[]
  trips   Trip[]
  fuel        FuelLog[]
  maintenance MaintenanceLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

/// Every expiring vehicle paper. Same rule as EmployeeDocument: a renewal is a
/// new row, never an edit, so history survives and alerts read the latest row.
model VehicleDocument {
  id        String    @id @default(cuid())
  vehicleId String
  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type      String // REGISTRATION | INSURANCE | INSPECTION | OTHER
  number    String?
  issuedOn  DateTime?
  expiresOn DateTime?
  /// Path to the scan on disk — never a DB blob (see EmployeeDocument).
  fileUrl String?
  notes   String?

  createdAt DateTime @default(now())

  @@index([vehicleId])
  @@index([expiresOn])
}

/// The driving role layered onto an existing Employee — the person stays one
/// Employee record (one payslip, one QID, one leave balance) and gains a Driver
/// row only while they drive. Deleting the employee removes the role with them.
model Driver {
  id         String   @id @default(cuid())
  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  licenceNo     String?
  licenceExpiry DateTime?

  /// The vehicle this driver normally takes; the allocator starts here and may
  /// still be overridden per trip. SetNull so retiring a vehicle never deletes
  /// a driver.
  defaultVehicleId String?
  defaultVehicle   Vehicle? @relation(fields: [defaultVehicleId], references: [id], onDelete: SetNull)

  /// Shift window in minutes from midnight — the bounds allocate() must respect.
  shiftStartMin Int?
  shiftEndMin   Int?

  active Boolean @default(true)
  notes  String?

  trips Trip[]
  pings DriverPing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

/* -------------------------- Transport: trips ------------------------------ */

/// One vehicle journey serving one or more passengers. Created by the planner's
/// generator (status PROPOSED, awaiting a human) or by hand (PLANNED).
model Trip {
  id     String   @id @default(cuid())
  /// The service day, stored at UTC midnight — the board is always "a day".
  date   DateTime
  status String   @default("PROPOSED") // PLANNED | PROPOSED | ASSIGNED | STARTED | COMPLETED | CANCELLED

  /// Deterministic identity of the ride this trip serves:
  /// `kind:passengerId:fromSession→toSession`. Re-running the generator for the
  /// same day must refresh the board, never duplicate it — this plus the
  /// [date, legKey] unique index is what makes generation idempotent.
  /// Null for manually created trips, which the generator leaves alone.
  legKey String?

  driverId  String?
  driver    Driver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  plannedStartMin Int
  plannedEndMin   Int
  estimatedKm     Decimal @default(0)
  estimatedMin    Int     @default(0)

  actualStartAt DateTime?
  actualEndAt   DateTime?
  actualKm      Decimal?

  /// Provenance and the numbers behind the proposal, kept so the board can
  /// explain *why* this driver was chosen rather than asking for blind trust.
  autoAllocated   Boolean  @default(false)
  allocationScore Decimal?

  /// Phase-1 validation: VALID | WARNING | INVALID. Approval is gated on this.
  validationStatus  String  @default("WARNING")
  /// Human-readable reasons a route needs review, JSON array of {code,text}.
  validationMessages String?
  needsReviewReason String?

  /// Revision / audit provenance (a session change proposes a new revision
  /// rather than mutating an approved trip).
  revisionNumber   Int     @default(1)
  supersedesTripId String?
  manualEdit       Boolean @default(false)

  overrideReason  String?
  overriddenById  String?
  overriddenAt    DateTime?
  approvedById    String?
  approvedAt      DateTime?
  deadheadKm      Decimal?
  slackMin        Int?

  /// OSRM encoded polyline for the whole route, so the board draws the real
  /// road path rather than straight segments. Null when built on the estimator.
  routeGeometry   String?

  /// Trip direction after the pickup/return split (C4): PICKUP (توصيل, homes
  /// → centre), RETURN (عودة, centre → homes), or CHAIN (a field round / an
  /// un-split day). Null on legacy trips.
  tripKind        String?
  /// Shared key linking the trips a single passenger's day was split into,
  /// so the board can group توصيل + عودة together.
  linkGroup       String?

  notes       String?
  createdById String?

  stops  TripStop[]
  events TripEvent[]
  pings  DriverPing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, legKey])
  @@index([date, status])
  @@index([driverId, date])
}

/// An ordered stop on a trip. Modelling stops (rather than a from/to pair on the
/// trip) is what makes house-to-house chains and shared rides expressible.
model TripStop {
  id     String @id @default(cuid())
  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  seq    Int
  kind   String // PICKUP | DROPOFF

  lat        Float
  lng        Float
  label      String
  plannedMin Int
  arrivedAt  DateTime?

  /// Operational-duration breakdown from the previous stop (all seconds). The
  /// raw routing time and each allowance are kept separately, never merged
  /// into one unexplained number.
  routingDurationS     Int?
  delayAllowanceS      Int?
  operationalDurationS Int?
  serviceDurationS     Int?
  distanceFromPrevM    Int?
  /// True while travel time is the straight-line estimate rather than a road
  /// network result (Phase 2 sets these to false once OSRM is live).
  estimated        Boolean @default(true)
  fallbackUsed     Boolean @default(true)
  validationStatus String?

  /// Exactly one passenger link is set. Two nullable columns beat a polymorphic
  /// id because the FK still protects them.
  passengerTeacherId String?
  passengerTeacher   Teacher? @relation(fields: [passengerTeacherId], references: [id], onDelete: SetNull)
  passengerStudentId String?
  passengerStudent   Student? @relation(fields: [passengerStudentId], references: [id], onDelete: SetNull)

  /// The lesson this stop serves — the link back to why the trip exists.
  sessionId String?
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  notes String?

  @@unique([tripId, seq])
  @@index([sessionId])
}

/// Append-only status history for a trip (same shape as ChequeEvent).
model TripEvent {
  id         String   @id @default(cuid())
  tripId     String
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  fromStatus String?
  toStatus   String
  note       String?
  byUserId   String?
  at         DateTime @default(now())

  @@index([tripId, at])
}

/// A driver's location fix while a trip is running.
///
/// The ONLY table here that grows without bound, so it is pruned by the daily
/// cron after `transportPingDays`. Written only while a trip is STARTED —
/// never in the background — and this is staff location data, so reads are
/// gated by the transportTrackingVisibility setting, server-side.
model DriverPing {
  id       String  @id @default(cuid())
  driverId String
  driver   Driver  @relation(fields: [driverId], references: [id], onDelete: Cascade)
  tripId   String?
  trip     Trip?   @relation(fields: [tripId], references: [id], onDelete: SetNull)

  lat Float
  lng Float
  /// Reported accuracy in metres. Fixes worse than the configured ceiling are
  /// rejected client-side; the column is kept so a stored path can be audited.
  accuracyM Int?

  at DateTime @default(now())

  @@index([driverId, at])
  @@index([tripId, at])
}

/// A fill-up. Creates an Expense so fleet running costs land in the same P&L as
/// everything else — with the accounting module on, the category's account
/// (5100 transport & fuel) posts it to the journal automatically. There is
/// deliberately no separate cost ledger to reconcile.
model FuelLog {
  id        String  @id @default(cuid())
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  date   DateTime
  litres Decimal
  cost   Decimal
  /// Reading at the pump. Fuel economy is only computable between two fills
  /// that both recorded one, so it is optional but worth chasing.
  odometerKm Int?

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  /// The expense this created. SetNull rather than Cascade: deleting an expense
  /// must not silently erase the fuel history it came from.
  expenseId String?  @unique
  expense   Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)

  notes String?

  createdAt DateTime @default(now())

  @@index([vehicleId, date])
}

/// Service, repair or tyres. Same expense linkage as FuelLog.
model MaintenanceLog {
  id        String  @id @default(cuid())
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  date        DateTime
  kind        String // SERVICE | REPAIR | TYRES | OTHER
  description String
  cost        Decimal
  odometerKm  Int?

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  expenseId  String?   @unique
  expense    Expense?  @relation(fields: [expenseId], references: [id], onDelete: SetNull)

  /// When the next service is due — by distance, by date, or both.
  nextDueKm Int?
  nextDueOn DateTime?

  notes String?

  createdAt DateTime @default(now())

  @@index([vehicleId, date])
}


/// A saved teaching group / course: a fixed roster taught together, each member
/// billed at their own agreed price. Distinct from an ad-hoc group booking,
/// which is a one-off selection priced from the matrix.
model StudentGroup {
  id           String      @id @default(cuid())
  name         String
  teacherId    String?
  teacher      Teacher?    @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  subjectId    String?
  subject      Subject?    @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  gradeLevelId String?
  gradeLevel   GradeLevel? @relation(fields: [gradeLevelId], references: [id])
  location     String      @default("CENTER") // CENTER | HOME
  /// Default hourly price. A member with no override inherits this; if this is
  /// null too, booking falls back to the grade/location price matrix.
  defaultPricePerHour Decimal?
  active       Boolean     @default(true)
  notes        String?

  members  GroupMember[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

/// One student's place in a group, with their own agreed price.
model GroupMember {
  id        String       @id @default(cuid())
  groupId   String
  group     StudentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  studentId String
  student   Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  /// Per-student hourly price. Null = the group default, then the matrix.
  pricePerHour Decimal?

  createdAt DateTime @default(now())

  @@unique([groupId, studentId])
  @@index([studentId])
}

/// Admin-defined roles layered on the fixed enum. Each carries a `baseRole`
/// capability (one of the built-in enum roles) so the existing route guards —
/// which check the session's capability — keep working unchanged; `permissions`
/// only narrows which modules show in the menu.
model CustomRole {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  nameEn      String?
  baseRole    String   // ADMIN | ACCOUNTANT | RECEPTIONIST | TEACHER | PARENT | DRIVER
  permissions String   @default("{}") // JSON navKey -> bool (menu visibility)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// The centre's physical buildings, their floors, and each floor's plan image.
/// Facilities reference data — no money or sessions hang off it yet, so both
/// models are standalone and safe to wipe/seed independently.
model Building {
  id        String   @id @default(cuid())
  name      String
  nameEn    String?
  address   String?
  notes     String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  floors    Floor[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Floor {
  id         String   @id @default(cuid())
  buildingId String
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  name       String
  level      Int      @default(0)
  /// Floor-plan image, stored inline as a data URL (like the centre logo).
  mapUrl     String?
  notes      String?
  rooms      Room[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([buildingId])
}

model Room {
  id        String   @id @default(cuid())
  floorId   String
  floor     Floor    @relation(fields: [floorId], references: [id], onDelete: Cascade)
  name      String
  code      String?
  /// Room use — classroom, lab, office, other.
  kind      String   @default("CLASSROOM")
  capacity  Int?
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([floorId])
}

/// Cached road-routing results (spec §12). Keyed by provider+profile+coord set;
/// a coordinate change misses automatically. Failed/fallback matrices are never
/// stored as authoritative. Pruned by TTL.
model RoutingCache {
  id        String   @id @default(cuid())
  cacheKey  String   @unique
  provider  String
  profile   String
  payload   String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}
