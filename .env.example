# ---- Database ----
# Local development uses SQLite (zero setup):
DATABASE_URL="file:./dev.db"
#
# For production, switch prisma/schema.prisma `datasource.provider` to
# "postgresql" and set a Postgres connection string, e.g. (Neon/Supabase):
# DATABASE_URL="postgresql://user:password@host:5432/edu_erp?sslmode=require"

# ---- Auth ----
# Secret used to sign session JWTs. Use a long random string in production
# (e.g. `openssl rand -base64 48`).
AUTH_SECRET="change-me-to-a-long-random-secret-min-32-chars"

# ---- Legacy import (optional) ----
# Absolute path to the center's existing workbook. If unset, the importer looks
# for a *.xlsx containing "مراكز" in the user's Downloads folder.
# WORKBOOK="C:/path/to/مراكز تعليمية.xlsx"

# --- Cron ---
# Shared secret for /api/cron (daily reminders). Generate with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
CRON_SECRET="change-me"
